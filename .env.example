# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finance_user:finance_pass@postgres:5432/finance_alerts
# For Alembic migrations (sync driver):
SYNC_DATABASE_URL=postgresql+psycopg2://finance_user:finance_pass@postgres:5432/finance_alerts

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── TELEGRAM ──────────────────────────────────────────────────────────────────
# Get from @BotFather: /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# Channel: @yourchannel  |  Group: -100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=@your_finance_alerts_channel

# ── SCORING ───────────────────────────────────────────────────────────────────
IMPACT_THRESHOLD=60

# ── ADMIN API ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=change_me_use_secrets_token_hex_32

# ── STRIPE ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── APP ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
# Sentry (optional)
SENTRY_DSN=

# ── POSTGRES (used by docker-compose) ─────────────────────────────────────────
POSTGRES_DB=finance_alerts
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=finance_pass
